# Database connection for load_to_database.py
# Copy this to .env and fill in your values

# Option 1: Full connection URL (preferred)
DATABASE_URL=postgresql://username:password@localhost:5432/baby_data

# Option 2: Individual parameters
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=baby_data
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SCHEMA=public
